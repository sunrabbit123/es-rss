{
  "name": "es-rss",
  "version": "0.0.0",
  "description": "A lightweight TypeScript library for parsing RSS and Atom feeds into structured JavaScript objects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome format --write",
    "release": "bumpp"
  },
  "keywords": [
    "rss",
    "atom",
    "feed",
    "parser",
    "xml"
  ],
  "license": "MIT",
  "bumpp": {
    "commit": "release: v%s",
    "tag": "v%s",
    "push": true,
    "all": true
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "bumpp": "^10.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
